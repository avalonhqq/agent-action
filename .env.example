# Copy this file to .env for local development.
BILI_SUPPORT_ENVIRONMENT=local
BILI_SUPPORT_DEBUG=false
BILI_SUPPORT_HOST=127.0.0.1
BILI_SUPPORT_PORT=8010
BILI_SUPPORT_LOG_LEVEL=INFO
BILI_SUPPORT_LLM_PROVIDER=mock
BILI_SUPPORT_LLM_BASE_URL=https://api.openai.com/v1
BILI_SUPPORT_LLM_MODEL=mock-support-model
BILI_SUPPORT_LLM_STRUCTURED_OUTPUT_MODE=json_schema
BILI_SUPPORT_LLM_MOCK_RESPONSE=这是来自确定性 Mock Provider 的客服回复。
BILI_SUPPORT_INTENT_MOCK_RESPONSE={"route":"supported","intents":[{"domain":"membership","action":"query","confidence":0.9}],"entities":[],"sentiment":"neutral","risk":"low","confidence":0.9,"needs_clarification":false,"clarification_question":null,"source":"model"}
BILI_SUPPORT_INTENT_PARSE_RETRIES=1
BILI_SUPPORT_LLM_MAX_RETRIES=2
BILI_SUPPORT_LLM_RETRY_BASE_DELAY=0.1
BILI_SUPPORT_LLM_TEMPERATURE=0.0
BILI_SUPPORT_LLM_MAX_TOKENS=512
BILI_SUPPORT_LLM_TIMEOUT_SECONDS=30.0
BILI_SUPPORT_DATABASE_URL=sqlite+aiosqlite:///./data/bili_support.db
BILI_SUPPORT_DATABASE_ECHO=false
BILI_SUPPORT_DATABASE_AUTO_CREATE=true
BILI_SUPPORT_REDIS_ENABLED=false
BILI_SUPPORT_REDIS_REQUIRED=false
BILI_SUPPORT_REDIS_URL=redis://127.0.0.1:6379/0
BILI_SUPPORT_REDIS_HISTORY_TTL_SECONDS=900
BILI_SUPPORT_REDIS_HISTORY_MAX_MESSAGES=100
BILI_SUPPORT_API_TOKEN=local-demo-token
BILI_SUPPORT_UI_ENABLED=true
BILI_SUPPORT_UI_PREFILL_DEMO_CREDENTIALS=false
BILI_SUPPORT_UI_STORAGE_SECRET=local-ui-storage-secret-change-me

# Set only in a local .env or secret manager; never commit a real key.
# BILI_SUPPORT_LLM_API_KEY=

# MySQL example (put the real password only in local .env or a secret manager):
# BILI_SUPPORT_DATABASE_URL=mysql+aiomysql://bili_support:change-me@127.0.0.1:3306/bili_support?charset=utf8mb4
